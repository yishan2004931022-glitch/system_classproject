<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>生存訊號 Survival Signal (高擬真運作版)</title>
    <style>
        :root {
            --bg-color: #0d0d0d; --panel-bg: #1a1a1a; --primary: #4da6ff;
            --safe-green: #2e7d32; --warn-yellow: #f57f17; --alert-red: #d32f2f;
            --text-main: #ffffff; --text-sub: #aaaaaa;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color); color: var(--text-main);
            display: flex; justify-content: center; align-items: center;
            height: 100vh; margin: 0; overflow: hidden;
        }

        .device-frame {
            width: 100%; max-width: 450px; height: 100%; max-height: 850px;
            background-color: var(--panel-bg); box-shadow: 0 20px 50px rgba(0,0,0,0.8);
            position: relative; display: flex; flex-direction: column; overflow: hidden;
        }

        @media (min-width: 600px) {
            .device-frame { height: 90vh; border-radius: 25px; border: 4px solid #333; }
        }

        /* 系統狀態列 (模擬手機頂部) */
        .status-bar {
            display: flex; justify-content: space-between; padding: 10px 20px;
            font-size: 12px; color: #888; background: #111;
        }

        .header {
            padding: 15px 20px; background: linear-gradient(180deg, #222, transparent);
            border-bottom: 1px solid #333; text-align: center; position: relative;
        }
        .header h1 { font-size: 20px; margin: 0; color: var(--primary); }
        .header p { font-size: 12px; color: var(--text-sub); margin: 5px 0 0; }
        .back-btn {
            position: absolute; left: 15px; top: 20px;
            background: none; border: none; color: var(--primary); font-size: 14px; cursor: pointer; display: none;
        }

        .screen {
            flex: 1; padding: 20px; display: none; flex-direction: column; overflow-y: auto;
            animation: slideIn 0.3s ease;
        }
        .screen.active { display: flex; }
        @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

        /* 按鈕設計 */
        .btn {
            width: 100%; padding: 18px; border: none; border-radius: 12px; font-size: 16px; font-weight: bold;
            color: white; cursor: pointer; margin-bottom: 15px; transition: all 0.2s;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
        }
        .btn:active { transform: scale(0.96); }
        .btn span { font-size: 12px; font-weight: normal; margin-top: 5px; opacity: 0.8; }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
        
        .btn-role { background-color: #2a2a2a; border: 1px solid #444; }
        .btn-green { background-color: var(--safe-green); }
        .btn-yellow { background-color: var(--warn-yellow); color: #fff; }
        .btn-red { background-color: var(--alert-red); animation: pulse-red 2s infinite; }
        
        @keyframes pulse-red { 0% { box-shadow: 0 0 0 0 rgba(211,47,47,0.5); } 70% { box-shadow: 0 0 0 10px rgba(211,47,47,0); } 100% { box-shadow: 0 0 0 0 rgba(211,47,47,0); } }

        /* 民眾端：問卷與雷達 */
        .symptom-item { display: flex; align-items: center; padding: 15px; background: #222; margin-bottom: 10px; border-radius: 10px; border: 1px solid #333; }
        .symptom-item input { width: 20px; height: 20px; margin-right: 15px; accent-color: var(--alert-red); }
        .radar { width: 60px; height: 60px; border: 4px solid var(--primary); border-top-color: transparent; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 20px; }
        @keyframes spin { 100% { transform: rotate(360deg); } }

        /* 地圖模擬器 */
        .map-container {
            background: #000; border: 1px solid #333; border-radius: 12px; height: 220px; position: relative;
            overflow: hidden; margin-bottom: 15px; background-image: radial-gradient(#222 1px, transparent 1px); background-size: 20px 20px;
        }
        .map-dot { position: absolute; width: 12px; height: 12px; border-radius: 50%; box-shadow: 0 0 10px currentColor; transition: all 1s ease; }
        .dot-red { background: var(--alert-red); color: var(--alert-red); top: 30%; left: 40%; animation: pulse 1s infinite; }
        .dot-yellow { background: var(--warn-yellow); color: var(--warn-yellow); top: 60%; left: 70%; }
        .dot-green { background: var(--safe-green); color: var(--safe-green); top: 20%; left: 80%; }
        
        .heatmap-overlay {
            position: absolute; top: 10%; left: 20%; width: 150px; height: 150px;
            background: radial-gradient(circle, rgba(211,47,47,0.6) 0%, rgba(211,47,47,0) 70%);
            display: none; border-radius: 50%; animation: pulse-heat 2s infinite alternate;
        }
        @keyframes pulse { 0% { transform: scale(0.8); } 50% { transform: scale(1.2); } 100% { transform: scale(0.8); } }
        @keyframes pulse-heat { from { transform: scale(0.8); opacity: 0.5; } to { transform: scale(1.3); opacity: 0.9; } }

        /* 數據卡片 */
        .data-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px; }
        .data-card { background: #222; padding: 15px 10px; border-radius: 10px; text-align: center; border: 1px solid #333; transition: all 0.3s; }
        .data-card h4 { margin: 0; font-size: 11px; color: #888; }
        .data-card p { margin: 5px 0 0; font-size: 24px; font-weight: bold; color: white; }
        .highlight { background: #1a3a1a; border-color: var(--safe-green); }

        #toast { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); background: #333; padding: 12px 24px; border-radius: 20px; font-size: 14px; opacity: 0; transition: 0.3s; pointer-events: none; z-index: 1000; white-space: nowrap; box-shadow: 0 5px 15px rgba(0,0,0,0.5); }
    </style>
</head>
<body>

<div class="device-frame">
    <div class="status-bar">
        <span id="clock">14:00</span>
        <span>5G 📶 100% 🔋</span>
    </div>

    <div class="header">
        <button class="back-btn" id="backBtn" onclick="logout()">◀ 登出</button>
        <h1 id="headerTitle">系統登入</h1>
        <p id="headerSub">Survival Signal Network</p>
    </div>

    <div id="screen-login" class="screen active" style="justify-content: center;">
        <button class="btn btn-role" onclick="login('public-main')">
            📱 一般民眾端
            <span>健康回報 / 請求救援</span>
        </button>
        <button class="btn btn-role" onclick="login('medical')">
            🏥 醫療指揮端
            <span>任務指派 / 資源調度</span>
        </button>
        <button class="btn btn-role" onclick="login('command')">
            🌐 國家戰情端
            <span>AI 預測 / 總體監控</span>
        </button>
    </div>

    <div id="screen-public-main" class="screen">
        <div style="background: #111; padding: 15px; border-radius: 12px; text-align: center; margin-bottom: 20px; border: 1px solid #333;">
            <div style="font-size: 12px; color: #aaa;">下次強制回報倒數</div>
            <div style="font-size: 32px; font-weight: bold; color: #4da6ff; margin-top: 5px;" id="countdown">05:59:59</div>
        </div>
        <button class="btn btn-green" onclick="resetTimer('安全已記錄，倒數重置')">🟢 我目前安全</button>
        <button class="btn btn-yellow" onclick="resetTimer('輕症已記錄，請居家觀察')">🟡 輕微不適</button>
        <button class="btn btn-red" onclick="navTo('public-symptoms')">🔴 緊急警報<span>出現嚴重症狀，請求分配醫療資源</span></button>
    </div>

    <div id="screen-public-symptoms" class="screen">
        <h3 style="color: var(--alert-red); margin-top: 0;">填寫變異症狀</h3>
        <label class="symptom-item"><input type="checkbox" class="symp-check"> 持續高燒 (>39°C)</label>
        <label class="symptom-item"><input type="checkbox" class="symp-check"> 嚴重呼吸困難</label>
        <label class="symptom-item"><input type="checkbox" class="symp-check"> 意識模糊 / 昏厥</label>
        <button class="btn btn-red" style="margin-top: auto;" onclick="submitSymptoms()">送出並由 AI 評估</button>
        <button class="btn btn-role" onclick="navTo('public-main')">取消</button>
    </div>

    <div id="screen-public-loading" class="screen" style="justify-content: center; text-align: center;">
        <div class="radar"></div>
        <h3 style="color: var(--primary);">量子演算法分配中</h3>
        <p style="color: #888; font-size: 14px;" id="loading-text">正在交叉比對全國病床資源...</p>
    </div>

    <div id="screen-public-result" class="screen" style="justify-content: center; text-align: center;">
        <div style="font-size: 50px; margin-bottom: 10px;">🚑</div>
        <h2 style="color: var(--alert-red);">醫療資源已鎖定</h2>
        <div style="background: #222; padding: 20px; border-radius: 10px; margin-bottom: 20px; text-align: left; line-height: 1.8;">
            優先級別：<strong style="color: var(--alert-red);">Code Red (極高)</strong><br>
            分派醫院：第三野戰醫院<br>
            接駁車輛：救護車 #TPE-402<br>
            預估抵達：<strong style="color: #ffb300;">12 分鐘</strong>
        </div>
        <button class="btn btn-role" onclick="navTo('public-main')">返回主頁面</button>
    </div>

    <div id="screen-medical" class="screen">
        <div style="display: flex; justify-content: space-between; margin-bottom: 10px; font-size: 12px;">
            <span style="color: var(--safe-green);">🔒 端到端加密連線中</span>
            <span>北區第 4 區塊</span>
        </div>
        <div class="map-container">
            <div class="map-dot dot-red" id="med-target"></div>
            <div class="map-dot dot-yellow"></div>
            <div class="map-dot dot-green"></div>
        </div>
        <div class="data-grid">
            <div class="data-card"><h4>待處理 Code Red</h4><p id="med-tasks" style="color: var(--alert-red);">2</p></div>
            <div class="data-card"><h4>可用救護車輛</h4><p id="med-ambs">5</p
